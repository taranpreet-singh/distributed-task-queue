MAX_RETRIES=3
CONCURRENCY=10

# Redis 
REDIS_URL=redis://localhost:6379
STREAM_KEY=tasks
CONSUMER_GROUP_KEY=workers
BLOCK_MS=5000
DLQ_STREAM_KEY=tasks:dlq
CLAIMED_IDLE_MS=60000
HEARTBEAT_MS=10000
BATCH_SIZE=10

# SMTP (defaults work with Mailhog: docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@example.com
# SMTP_USER=
# SMTP_PASS=
