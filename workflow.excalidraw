    {
      "id": "redis-commands-note",
      "type": "text",
      "x": 905.0938737824805,
      "y": 473.7719445588659,
      "width": 410.7315673828125,
      "height": 122.5,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 54,
      "version": 392,
      "versionNonce": 1595373932,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781910725201,
      "link": null,
      "locked": false,
      "text": "Redis Commands:\n- XADD → add msg to stream (MaxLen ~100k, Approx=true)\n- XREADGROUP \">\" → read undelivered, add to PEL\n- XAUTOCLAIM → reclaim idle PEL entries (cursor loop)\n- XCLAIM (MinIdle=0) → heartbeat: reset idle timer\n- XACK → remove from PEL on success / DLQ\n- XPendingExt → read PEL delivery count for retry logic",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Redis Commands:\n- XADD → add msg to stream (MaxLen ~100k, Approx=true)\n- XREADGROUP \">\" → read undelivered, add to PEL\n- XAUTOCLAIM → reclaim idle PEL entries (cursor loop)\n- XCLAIM (MinIdle=0) → heartbeat: reset idle timer\n- XACK → remove from PEL on success / DLQ\n- XPendingExt → read PEL delivery count for retry logic",
      "lineHeight": 1.25,
      "index": "aU",
      "autoResize": true
    },
    {
      "id": "shutdown-note",
      "type": "text",
      "x": 898.7403113030028,
      "y": 619.7641407866914,
      "width": 294.209716796875,
      "height": 70,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 55,
      "version": 379,
      "versionNonce": 1720531052,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781910862660,
      "link": null,
      "locked": false,
      "text": "Graceful Shutdown (SIGINT / SIGTERM):\n- signal.NotifyContext cancels ctx\n- Run() loop exits on ctx.Done()\n- defer w.Close() → wg.Wait() + rdb.Close()",
      "fontSize": 14,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Graceful Shutdown (SIGINT / SIGTERM):\n- signal.NotifyContext cancels ctx\n- Run() loop exits on ctx.Done()\n- defer w.Close() → wg.Wait() + rdb.Close()",
      "lineHeight": 1.25,
      "index": "aV",
      "autoResize": true
    },
